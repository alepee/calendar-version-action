{
    "name": "calendar-version-action",
    "version": "1.0.0",
    "description": "GitHub Action for Calendar Versioning",
    "main": "dist/index.js",
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --minify --outfile=dist/index.js",
        "test": "jest --coverage=false",
        "test:coverage": "jest --coverage",
        "lint": "eslint .",
        "prepare": "husky",
        "pre-commit": "npm run build && git add dist"
    },
    "keywords": [
        "github",
        "actions",
        "versioning",
        "calver"
    ],
    "author": {
        "name": "Antoine Lépée",
        "email": "service+gh@antoine.io",
        "url": "https://github.com/alepee"
    },
    "contributors": [
        {
            "name": "Claude",
            "email": "claude@anthropic.com",
            "url": "https://claude.ai"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alepee/calendar-version-action.git"
    },
    "bugs": {
        "url": "https://github.com/alepee/calendar-version-action/issues"
    },
    "homepage": "https://github.com/alepee/calendar-version-action#readme",
    "license": "MIT",
    "dependencies": {
        "@actions/core": "^3.0.1",
        "@actions/exec": "^3.0.0",
        "@actions/github": "^9.1.1",
        "@octokit/rest": "^22.0.1",
        "date-fns": "^3.3.1"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^24.12.2",
        "esbuild": "^0.28.0",
        "eslint": "^8.56.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "ts-jest": "^29.4.9",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
